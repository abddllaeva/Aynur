token game and finding max
public static int bagOfTokensScore(int[] tokens, int power) {
    Arrays.sort(tokens);
    int l=0,r=tokens.length-1,s=0,m=0;
    while(l<=r&&(power>=tokens[l]||s>0))
        if(power>=tokens[l]){m=Math.max(m,++s);power-=tokens[l++];}
        else{power+=tokens[r--];s--;}
    return m;
}





