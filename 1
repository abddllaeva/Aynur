public static int largestPerimeter(int[] a) {
    Arrays.sort(a);
    for(int i=a.length-1;i>=2;i--)
        if(a[i-2]+a[i-1]>a[i])return a[i-2]+a[i-1]+a[i];
    return 0;
}




public static int largestPerimeter(int[] nums) {
    Arrays.sort(nums);

    for (int i = nums.length - 1; i >= 2; i--) {
        int a = nums[i - 2];
        int b = nums[i - 1];
        int c = nums[i];

        if (a + b > c)
            return a + b + c;
    }

    return 0;
}

