public static String[] findWords(String[] words) {
    String[] r={"qwertyuiop","asdfghjkl","zxcvbnm"};
    return Arrays.stream(words).filter(w->Arrays.stream(r).anyMatch(s->w.toLowerCase().chars().allMatch(c->s.indexOf(c)>=0))).toArray(String[]::new);
}
