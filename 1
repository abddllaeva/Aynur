public static int findMiddle(Node head) {
    Node s=head, f=head;
    while(f!=null&&f.next!=null){s=s.next;f=f.next.next;}
    return s.data;
}



public static int findMiddle(Node head) {
    Node slow = head;
    Node fast = head;

    while (fast != null && fast.next != null) {
        slow = slow.next;
        fast = fast.next.next;
    }

    return slow.data;
}
